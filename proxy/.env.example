# ClarityDSM proxy environment variables.
# On Render, set these in the service's Environment tab (do NOT commit real values).

# Your single Anthropic API key (from console.anthropic.com). Held only here.
ANTHROPIC_API_KEY=sk-ant-...

# Shared access code users enter in the app. Pick something long and random.
# The server refuses to start without it.
ACCESS_CODE=choose-a-long-random-code

# Comma-separated origins allowed to call the proxy (the deployed site + local dev).
# Leave blank to allow any origin (the access code still gates use).
ALLOWED_ORIGINS=https://gregbutler205-jpg.github.io,http://localhost:5199

# Render sets PORT automatically; only needed for local runs.
PORT=8787
